  m_Name: Dialogue_Nurse
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: nurse_dialogue
  startNodeId: start
  startsFetchQuestOnEnd: 0
  nodes:
  - nodeId: start
    npcText: "\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0432 \u043F\u043E\u0435\u0437\u0434\u0435
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0442\u0438\u0445\u043E. \u041C\u043D\u0435
      \u044D\u0442\u043E \u0441\u043E\u0432\u0441\u0435\u043C \u043D\u0435 \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F."
    choices:
    - choiceText: "\u0412\u044B \u0447\u0435\u0433\u043E-\u0442\u043E \u0431\u043E\u0438\u0442\u0435\u0441\u044C?"
      nextNodeId: fear
      endsDialogue: 0
    - choiceText: "\u042F \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044E\u0441\u044C."
      nextNodeId: observe
      endsDialogue: 0
    - choiceText: "\u041C\u043D\u0435 \u043D\u0435\u043A\u043E\u0433\u0434\u0430
        \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u0442\u044C."
      nextNodeId: rude_end
      endsDialogue: 0
  - nodeId: fear
    npcText: "\u0414\u0430. \u0418\u043D\u043E\u0433\u0434\u0430 \u043C\u043D\u0435
      \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u043F\u043E\u0435\u0437\u0434
      \u0431\u0443\u0434\u0442\u043E \u0434\u044B\u0448\u0438\u0442. \u041A\u0430\u043A
      \u0436\u0438\u0432\u043E\u0439 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C."
    choices:
    - choiceText: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E..."
      nextNodeId: //
      endsDialogue: 1
  - nodeId: observe
    npcText: "\u0422\u043E\u0433\u0434\u0430 \u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435
      \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0435\u0435. \u0417\u0434\u0435\u0441\u044C
      \u043C\u043D\u043E\u0433\u043E\u0435 \u043D\u0435 \u0442\u043E, \u0447\u0435\u043C
      \u043A\u0430\u0436\u0435\u0442\u0441\u044F."
    choices:
    - choiceText: "\u042F \u0437\u0430\u043F\u043E\u043C\u043D\u044E \u044D\u0442\u043E."
      nextNodeId: //
      endsDialogue: 1
  - nodeId: rude_end
    npcText: "\u041A\u0430\u043A \u0445\u043E\u0442\u0438\u0442\u0435. \u041D\u043E
      \u043A\u043E\u0433\u0434\u0430 \u0441\u0442\u0430\u043D\u0435\u0442 \u043F\u043E\u0437\u0434\u043D\u043E,
      \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u0442\u044C
      \u0431\u0443\u0434\u0435\u0442 \u0443\u0436\u0435 \u043D\u0435\u043A\u043E\u0433\u043E."
    choices:
    - choiceText: ...
      nextNodeId: //
      endsDialogue: 1
