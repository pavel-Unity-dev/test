  m_Script: {fileID: 11500000, guid: b8b15681fd0848d449ff337e4171ef99, type: 3}
  m_Name: Dialogue_Nonlinear
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: nonlinear_dialogue
  startNodeId: start
  nodes:
  - nodeId: start
    npcText: "\u041A\u0442\u043E \u0432\u044B \u0442\u0430\u043A\u043E\u0439 \u0438
      \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442\u0435 \u0437\u0434\u0435\u0441\u044C
      \u0432 \u0442\u0430\u043A\u043E\u0439 \u0447\u0430\u0441?"
    choices:
    - choiceText: "\u042F \u0432\u0440\u0430\u0447. \u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E
        \u043F\u0440\u043E\u0439\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435."
      nextNodeId: doctor_reply
      endsDialogue: 0
    - choiceText: "\u042F \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0430\u0441\u0441\u0430\u0436\u0438\u0440."
      nextNodeId: passenger_reply
      endsDialogue: 0
    - choiceText: "\u042D\u0442\u043E \u043D\u0435 \u0432\u0430\u0448\u0435 \u0434\u0435\u043B\u043E."
      nextNodeId: rude_reply
      endsDialogue: 0
  - nodeId: doctor_reply
    npcText: "\u0415\u0441\u043B\u0438 \u0432\u044B \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u0432\u0440\u0430\u0447, \u0442\u043E\u0433\u0434\u0430 \u043D\u0435 \u043C\u0435\u0448\u043A\u0430\u0439\u0442\u0435.
      \u0423 \u043D\u0430\u0441 \u043C\u0430\u043B\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
    choices:
    - choiceText: "\u041F\u043E\u043D\u044F\u043B."
      nextNodeId: '``'
      endsDialogue: 1
  - nodeId: passenger_reply
    npcText: "\u041F\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u044B \u0434\u0430\u0432\u043D\u043E
      \u043D\u0435 \u0445\u043E\u0434\u044F\u0442 \u0442\u0443\u0442 \u0431\u0435\u0437
      \u043F\u0440\u0438\u0447\u0438\u043D\u044B. \u0411\u0443\u0434\u044C\u0442\u0435
      \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u044B."
    choices:
    - choiceText: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u0435."
      nextNodeId: '``'
      endsDialogue: 1
  - nodeId: rude_reply
    npcText: "\u0422\u043E\u0433\u0434\u0430 \u044F \u043D\u0435 \u0441\u0442\u0430\u043D\u0443
      \u0432\u0430\u043C \u043F\u043E\u043C\u043E\u0433\u0430\u0442\u044C. \u0418\u0434\u0438\u0442\u0435
      \u0441\u0432\u043E\u0435\u0439 \u0434\u043E\u0440\u043E\u0433\u043E\u0439."
    choices:
    - choiceText: ...
      nextNodeId: '``'
      endsDialogue: 1
